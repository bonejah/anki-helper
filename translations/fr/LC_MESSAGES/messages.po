#: templates/index.html:55
msgid "French → English + Portuguese"
msgstr "Français → Anglais + Portugais"

#: templates/index.html:56
msgid "English → French + Portuguese"
msgstr "Anglais → Français + Portugais"

#: templates/index.html:57
msgid "Portuguese → English + French"
msgstr "Portugais → Anglais + Français"

#: templates/index.html:58
msgid "Other languages are not supported at the moment"
msgstr "Les autres langues ne sont pas prises en charge pour le moment"

