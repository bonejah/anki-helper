#: templates/index.html:7
msgid "Translator and Anki Helper"
msgstr "Traducteur et assistant Anki"

#: templates/index.html:16
msgid "Translating and saving to Anki..."
msgstr "Traduction et enregistrement dans Anki..."

#: templates/index.html:44
msgid "Trilingual translator + Anki"
msgstr "Traducteur trilingue + Anki"

#: templates/index.html:45
msgid "Turn words into learning"
msgstr "Transformez les mots en apprentissage"

#: templates/index.html:47
msgid ""
"Translate words and expressions between French, English and Portuguese, "
"save them to Anki and review\n"
"          later."
msgstr "Traduisez des mots et expressions entre le français, l’anglais et le portugais, enregistrez-les dans Anki et révisez-les plus tard."

#: templates/index.html:53
msgid "Supported languages"
